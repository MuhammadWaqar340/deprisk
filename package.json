{
  "name": "deprisk-check",
  "version": "0.5.0",
  "description": "Check whether an npm dependency update actually risks your project's used APIs",
  "type": "module",
  "bin": {
    "deprisk": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "dependency",
    "risk",
    "npm",
    "typescript",
    "api-diff",
    "dependabot",
    "renovate",
    "github-action"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "pacote": "^22.0.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pacote": "^11.1.8",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
